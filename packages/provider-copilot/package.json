{
  "name": "@floway-dev/provider-copilot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": { "import": "./src/index.ts", "types": "./src/index.ts" },
    "./interceptors/chat-completions": { "import": "./src/interceptors/chat-completions/index.ts", "types": "./src/interceptors/chat-completions/index.ts" },
    "./interceptors/messages": { "import": "./src/interceptors/messages/index.ts", "types": "./src/interceptors/messages/index.ts" },
    "./interceptors/responses": { "import": "./src/interceptors/responses/index.ts", "types": "./src/interceptors/responses/index.ts" },
    "./interceptors/*": { "import": "./src/interceptors/*.ts", "types": "./src/interceptors/*.ts" },
    "./*": { "import": "./src/*.ts", "types": "./src/*.ts" }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@floway-dev/interceptor": "workspace:*",
    "@floway-dev/protocols": "workspace:*",
    "@floway-dev/provider": "workspace:*"
  },
  "devDependencies": {
    "@floway-dev/test-utils": "workspace:*"
  }
}
